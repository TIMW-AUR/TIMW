pkgname=spirv-headers
pkgver=r698.3786ee8
pkgrel=1
arch=(x86_64)
makedepends=(cmake git ninja)
groups=(vulkan-devel)
source=(SPIRV-Headers::git+https://github.com/KhronosGroup/SPIRV-Headers.git#commit=3786ee89d584f5ba46f31dc5253e6dfaa222e5c1)

build() {
  cmake -S SPIRV-Headers -B _build -G Ninja \
        -D CMAKE_BUILD_TYPE=Release \
        -D CMAKE_INSTALL_PREFIX=/usr \
        -Wno-dev
  cmake --build _build
}

package() {
  DESTDIR="$pkgdir" cmake --install _build
}
